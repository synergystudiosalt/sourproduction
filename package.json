{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:worker": "esbuild src/worker.ts --bundle --platform=neutral --format=esm --target=es2020 --outfile=dist/worker.mjs",
    "build": "vite build && npm run build:worker",
    "build:cloudflare": "vite build && npm run build:worker",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.cjs",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@google/genai": "^2.4.0",
    "@lezer/highlight": "^1.2.3",
    "@tailwindcss/vite": "^4.1.14",
    "@uiw/codemirror-themes": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "katex": "^0.18.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.114.0"
  }
}
